# SRI Labs PR Intelligence Dashboard
# Copy to .env and fill in your values

PORT=3000

# News API — get a key at https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# Meta (Instagram + Facebook) OAuth
# Create an app at https://developers.facebook.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://your-server-ip:3000/auth/meta/callback

# Instagram handle
INSTAGRAM_HANDLE=sri_labs_

# Websites to scrape (comma-separated)
WEBSITE_URLS=https://srilabs.com,https://skinresearchinstitute.com
